<section class="featured-collections">
  <div class="section-header">
    {% if section.settings.heading != blank %}
      <h2>{{ section.settings.heading | escape }}</h2>
    {% endif %}
    {% if section.settings.subheading != blank %}
      <p>{{ section.settings.subheading | escape }}</p>
    {% endif %}
  </div>

  <div class="collections-grid">
    {% for block in section.blocks %}
      {% assign collection = collections[block.settings.collection] %}
      <div class="collection-card" {{ block.shopify_attributes }}>
        <span class="card-icon">{{ block.settings.icon }}</span>

        {% if block.settings.title != blank %}
          <h3 class="{% cycle 'color-teal', 'color-pink' %}">{{ block.settings.title | escape }}</h3>
        {% elsif collection != blank %}
          <h3 class="{% cycle 'color-teal', 'color-pink' %}">{{ collection.title | escape }}</h3>
        {% endif %}

        {% if block.settings.description != blank %}
          <p>{{ block.settings.description | escape }}</p>
        {% elsif collection != blank and collection.description != blank %}
          <p>{{ collection.description | strip_html | truncatewords: 15 }}</p>
        {% endif %}

        <a
          href="{{ block.settings.link | default: collection.url | default: '#' }}"
          class="card-btn {% cycle 'btn-teal', 'btn-pink' %}"
        >
          {{ block.settings.button_text | default: 'Browse Now' | escape }}
        </a>
      </div>
    {% else %}
      <!-- Default fallback blocks -->
      <div class="collection-card">
        <span class="card-icon">📱</span>
        <h3 class="color-teal">Digital Downloads</h3>
        <p>Instant access to printable art, planners, and digital resources</p>
        <a href="/collections/digital-downloads" class="card-btn btn-teal">Browse Now</a>
      </div>
      <div class="collection-card">
        <span class="card-icon">👕</span>
        <h3 class="color-pink">Print on Demand</h3>
        <p>Custom apparel, mugs, and accessories with unique designs</p>
        <a href="/collections/pod-apparel" class="card-btn btn-pink">Shop POD</a>
      </div>
      <div class="collection-card">
        <span class="card-icon">📝</span>
        <h3 class="color-teal">Creative Templates</h3>
        <p>Professional templates for social media, branding, and more</p>
        <a href="/collections/templates" class="card-btn btn-teal">Explore Templates</a>
      </div>
      <div class="collection-card">
        <span class="card-icon">🎄</span>
        <h3 class="color-pink">Seasonal Designs</h3>
        <p>Celebrate every season with themed artwork and decorations</p>
        <a href="/collections/seasonal" class="card-btn btn-pink">Shop Seasonal</a>
      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Featured Collections",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Explore Our Collections"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Discover unique digital downloads and print-on-demand products made for creators like you"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon (emoji)",
          "default": "📱",
          "info": "An emoji or short text displayed above the title."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Collection Title",
          "info": "If empty, the linked collection's title is used."
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "info": "If empty, the linked collection's description is used."
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Link to collection"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Custom link",
          "info": "Overrides the collection link if set."
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button text",
          "default": "Browse Now"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Collections",
      "category": "Collections",
      "blocks": [
        { "type": "collection", "settings": { "icon": "📱", "title": "Digital Downloads", "description": "Instant access to printable art, planners, and digital resources", "button_text": "Browse Now" } },
        { "type": "collection", "settings": { "icon": "👕", "title": "Print on Demand", "description": "Custom apparel, mugs, and accessories with unique designs", "button_text": "Shop POD" } },
        { "type": "collection", "settings": { "icon": "📝", "title": "Creative Templates", "description": "Professional templates for social media, branding, and more", "button_text": "Explore Templates" } },
        { "type": "collection", "settings": { "icon": "🎄", "title": "Seasonal Designs", "description": "Celebrate every season with themed artwork and decorations", "button_text": "Shop Seasonal" } }
      ]
    }
  ]
}
{% endschema %}
