<section class="page-hero">
  <div class="deco-circle deco-circle-1"></div>
  <div class="deco-circle deco-circle-2"></div>
  <div class="page-hero-content">
    <h1>Search</h1>
    <form action="{{ routes.search_url }}" method="get" class="newsletter-form" style="margin-top: 20px;">
      <input type="search" name="q" placeholder="Search products..." value="{{ search.terms | escape }}" aria-label="Search">
      <button type="submit" class="btn btn-teal">Search</button>
    </form>
  </div>
</section>

<section class="collection-page">
  <div class="products-grid">
    {% if search.performed %}
      {% if search.results.size > 0 %}
        {% for item in search.results %}
          {% if item.object_type == 'product' %}
            {% render 'product-card', product: item %}
          {% endif %}
        {% endfor %}
      {% else %}
        <div class="empty-collection">
          <p>No results found.</p>
        </div>
      {% endif %}
    {% endif %}
  </div>

  {% if paginate.pages > 1 %}
    <div class="pagination">
      {{ paginate | default_pagination }}
    </div>
  {% endif %}
</section>

{% schema %}
{
  "name": "Search",
  "settings": [],
  "presets": [
    {
      "name": "Search",
      "category": "Main"
    }
  ]
}
{% endschema %}
