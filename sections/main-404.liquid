<section class="page-hero">
  <div class="deco-circle deco-circle-1"></div>
  <div class="deco-circle deco-circle-2"></div>
  <div class="page-hero-content">
    <h1>404</h1>
    <p>The page you were looking for does not exist.</p>
    <a href="{{ routes.root_url }}" class="btn btn-teal" style="margin-top: 20px;">
      Back to Home
    </a>
  </div>
</section>

<section class="page-content" style="padding-top: 0;">
  <div class="page-content-inner" style="text-align: center;">
    <p>Maybe you want to try the search instead?</p>
    <form action="{{ routes.search_url }}" method="get" class="newsletter-form" style="margin-top: 20px;">
      <input type="search" name="q" placeholder="Search..." value="{{ search.terms | escape }}" aria-label="Search">
      <button type="submit" class="btn btn-teal">Search</button>
    </form>
  </div>
</section>

{% schema %}
{
  "name": "404 page",
  "settings": [],
  "presets": [
    {
      "name": "404 page",
      "category": "Main"
    }
  ]
}
{% endschema %}
