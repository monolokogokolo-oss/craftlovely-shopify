<header class="site-header">
  <div class="header-container">
    <div class="logo-container">
      <a href="{{ routes.root_url }}">
        {% if section.settings.logo != blank %}
          <img src="{{ section.settings.logo | img_url: '300x' }}" alt="{{ shop.name }}" class="logo-img" loading="lazy" width="auto" height="60">
        {% else %}
          <div class="site-logo-text">{{ section.settings.logo_text | escape }}<span>{{ section.settings.logo_text_highlight | escape }}</span></div>
        {% endif %}
      </a>
      {% if section.settings.show_tagline %}
        <p class="tagline">{{ section.settings.tagline | escape }}</p>
      {% endif %}
    </div>

    <div class="nav-row">
      <button class="menu-toggle" id="menuToggle" aria-label="{{ 'accessibility.toggle_menu' | t | default: 'Toggle navigation' }}">
        <i class="fas fa-bars"></i>
      </button>

      <nav class="main-nav" id="mainNav">
        <ul>
          {% if section.settings.menu != blank %}
            {% for link in section.settings.menu.links %}
              <li>
                <a href="{{ link.url }}" {% if link.active %}class="active"{% endif %}>{{ link.title | escape }}</a>
              </li>
            {% endfor %}
          {% else %}
            <li><a href="/" class="active">Home</a></li>
            <li><a href="/collections/all">Shop</a></li>
            <li><a href="#">Collections</a></li>
            <li><a href="#">About</a></li>
            <li><a href="#">Contact</a></li>
          {% endif %}
        </ul>
      </nav>

      <div class="nav-icons">
        <a href="{{ routes.search_url }}" aria-label="{{ 'accessibility.search' | t | default: 'Search' }}">
          <i class="fas fa-search"></i>
        </a>
        <a href="{{ routes.account_url }}" aria-label="{{ 'accessibility.account' | t | default: 'Account' }}">
          <i class="fas fa-user"></i>
        </a>
        <a href="{{ routes.cart_url }}" aria-label="{{ 'accessibility.cart' | t | default: 'Shopping cart' }}" class="cart-icon">
          <i class="fas fa-shopping-cart"></i>
          <span class="cart-count">{{ cart.item_count }}</span>
        </a>
      </div>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image",
      "info": "300px wide recommended. If empty, text logo is used."
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text",
      "default": "Craft"
    },
    {
      "type": "text",
      "id": "logo_text_highlight",
      "label": "Logo text highlight",
      "default": "Lovely",
      "info": "This portion appears in pink."
    },
    {
      "type": "checkbox",
      "id": "show_tagline",
      "label": "Show tagline",
      "default": true
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Create • Inspire • Share"
    },
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
